# ─────────────────────────────────────────────────────────────────────────────
# Ask Everything — Environment / Settings
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Claude API ──────────────────────────────────────────────────────────────
# Your Anthropic API key.  Required.  Obtain one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Global hotkey ───────────────────────────────────────────────────────────
# Key combination that opens the overlay.
# Uses the `keyboard` library's hotkey syntax.
HOTKEY=ctrl+shift+space

# ── Search / results ────────────────────────────────────────────────────────
# Number of results returned per page (20–200).
MAX_RESULTS=20

# Default sort column: name | path | size | date_modified
DEFAULT_SORT_COLUMN=date_modified

# Default sort direction: asc | desc
DEFAULT_SORT_DIRECTION=desc

# ── Cache ────────────────────────────────────────────────────────────────────
# Enable persistent SQLite cache for NL → query translations.
CACHE_ENABLED=true

# Time-to-live for cached entries in seconds (default: 86400 = 24 hours).
CACHE_TTL=86400

# ── Everything ───────────────────────────────────────────────────────────────
# Full path to Everything.exe.  Used for auto-launch if Everything is not running.
# Leave blank to disable auto-launch.
EVERYTHING_PATH=C:\Program Files\Everything\Everything.exe

# Validate that result paths still exist before displaying them (disable for
# large/network drives where stat() would be slow).
RESULT_VALIDATION=true

# ── UI ───────────────────────────────────────────────────────────────────────
# Theme: auto | light | dark
THEME=auto

# Base font size in points.
FONT_SIZE=11

# Overlay window opacity (0.85–1.0).
WINDOW_OPACITY=0.95
